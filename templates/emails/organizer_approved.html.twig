<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Organizer Account Approved</title>
</head>
<body style="margin:0; padding:0; background:#f4f7fb; font-family:Arial, Helvetica, sans-serif; color:#1f2937;">
<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#f4f7fb; padding:32px 16px;">
    <tr>
        <td align="center">
            <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="max-width:640px; background:#ffffff; border-radius:16px; overflow:hidden; border:1px solid #e5e7eb;">
                <tr>
                    <td style="padding:32px; background:linear-gradient(135deg, #0f2027 0%, #1a3a3a 100%); color:#ffffff;">
                        <div style="font-size:13px; letter-spacing:1.2px; text-transform:uppercase; opacity:0.8; color:#2EC4A1;">TicketHub</div>
                        <h1 style="margin:12px 0 0; font-size:26px; line-height:1.2;">Organizer Approved</h1>
                    </td>
                </tr>
                <tr>
                    <td style="padding:32px;">
                        <p style="margin:0 0 16px; font-size:16px; line-height:1.7;">
                            Hi <strong>{{ name }}</strong>,
                        </p>
                        <p style="margin:0 0 20px; font-size:15px; line-height:1.7; color:#4b5563;">
                            Your organizer account has been approved by the admin team.
                        </p>
                        <p style="margin:0 0 20px; font-size:15px; line-height:1.7; color:#4b5563;">
                            You can now log in with <strong>{{ email }}</strong> and start creating events.
                        </p>
                        <a href="{{ absolute_url(path('app_react', { reactRouting: 'login' })) }}"
                           style="display:inline-block; padding:10px 18px; font-size:13px; font-weight:700; color:#ffffff; background:#2EC4A1; border-radius:8px; text-decoration:none;">
                            Log In
                        </a>
                    </td>
                </tr>
                <tr>
                    <td style="padding:20px 32px; background:#f9fafb; border-top:1px solid #e5e7eb; font-size:12px; color:#9ca3af; text-align:center;">
                        TicketHub &mdash; This is an automated message, please do not reply.
                    </td>
                </tr>
            </table>
        </td>
    </tr>
</table>
</body>
</html>

