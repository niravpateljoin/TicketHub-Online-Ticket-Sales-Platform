<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verify New Administrator Email</title>
</head>
<body style="margin:0; padding:0; background:#f4f7fb; font-family:Arial, Helvetica, sans-serif; color:#1f2937;">
    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#f4f7fb; padding:32px 16px;">
        <tr>
            <td align="center">
                <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="max-width:640px; background:#ffffff; border-radius:16px; overflow:hidden; border:1px solid #e5e7eb;">
                    <tr>
                        <td style="padding:32px 32px 20px; background:linear-gradient(135deg, #0f172a 0%, #1f2937 100%); color:#ffffff;">
                            <div style="font-size:13px; letter-spacing:1.2px; text-transform:uppercase; opacity:0.8;">TicketHub</div>
                            <h1 style="margin:12px 0 0; font-size:28px; line-height:1.2;">Verify New Email Address</h1>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:32px;">
                            <p style="margin:0 0 16px; font-size:16px; line-height:1.7;">
                                An administrator email change was requested for <strong>{{ administrator.name ?? administrator.email }}</strong>.
                            </p>
                            <p style="margin:0 0 12px; font-size:15px; line-height:1.7; color:#4b5563;">
                                Current email: <strong>{{ currentEmail }}</strong><br>
                                New email: <strong>{{ newEmail }}</strong>
                            </p>
                            <p style="margin:0 0 24px; font-size:16px; line-height:1.7; color:#4b5563;">
                                Verify the new email address before it replaces the current login email.
                            </p>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin:0 0 24px;">
                                <tr>
                                    <td align="center" style="border-radius:10px; background:#10b981;">
                                        <a href="{{ verificationUrl }}" style="display:inline-block; padding:14px 24px; font-size:15px; font-weight:700; color:#ffffff; text-decoration:none;">
                                            Verify New Email
                                        </a>
                                    </td>
                                </tr>
                            </table>

                            <div style="margin:0 0 24px; padding:16px; border:1px solid #dbeafe; background:#eff6ff; border-radius:12px;">
                                <div style="margin:0 0 8px; font-size:13px; font-weight:700; text-transform:uppercase; letter-spacing:0.04em; color:#1d4ed8;">Verification Link</div>
                                <div style="font-size:14px; line-height:1.6; word-break:break-all; color:#1f2937;">
                                    <a href="{{ verificationUrl }}" style="color:#2563eb; text-decoration:none;">{{ verificationUrl }}</a>
                                </div>
                            </div>

                            <p style="margin:0; font-size:14px; line-height:1.7; color:#6b7280;">
                                Until this new email is verified, the current administrator email stays active.
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
