<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Booking Confirmed — {{ booking.event.name }}</title>
</head>
<body style="margin:0; padding:0; background:#f4f7fb; font-family:Arial, Helvetica, sans-serif; color:#1f2937;">
<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#f4f7fb; padding:32px 16px;">
    <tr>
        <td align="center">
            <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="max-width:640px; background:#ffffff; border-radius:16px; overflow:hidden; border:1px solid #e5e7eb;">

                <!-- Header -->
                <tr>
                    <td style="padding:32px 32px 20px; background:linear-gradient(135deg, #0f2027 0%, #1a3a3a 100%); color:#ffffff;">
                        <div style="font-size:13px; letter-spacing:1.2px; text-transform:uppercase; opacity:0.8; color:#2EC4A1;">TicketSphere</div>
                        <h1 style="margin:12px 0 0; font-size:26px; line-height:1.2;">Booking Confirmed!</h1>
                    </td>
                </tr>

                <!-- Body -->
                <tr>
                    <td style="padding:32px;">
                        <p style="margin:0 0 16px; font-size:16px; line-height:1.7;">
                            Hi <strong>{{ booking.user.name ?: booking.user.email }}</strong>,
                        </p>
                        <p style="margin:0 0 24px; font-size:15px; line-height:1.7; color:#4b5563;">
                            Your booking for <strong>{{ booking.event.name }}</strong> is confirmed. Your e-tickets are being generated and will be available in your account shortly.
                        </p>

                        <!-- Booking summary box -->
                        <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%"
                               style="margin:0 0 24px; border:1px solid #e5e7eb; border-radius:12px; overflow:hidden;">
                            <tr>
                                <td style="padding:16px 20px; background:#f9fafb; border-bottom:1px solid #e5e7eb;">
                                    <strong style="font-size:13px; text-transform:uppercase; letter-spacing:0.05em; color:#6b7280;">Booking Summary</strong>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding:20px;">
                                    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                                        <tr>
                                            <td style="padding:4px 0; font-size:14px; color:#6b7280; width:140px;">Event</td>
                                            <td style="padding:4px 0; font-size:14px; font-weight:600; color:#1f2937;">{{ booking.event.name }}</td>
                                        </tr>
                                        <tr>
                                            <td style="padding:4px 0; font-size:14px; color:#6b7280;">Date &amp; Time</td>
                                            <td style="padding:4px 0; font-size:14px; color:#1f2937;">{{ booking.event.dateTime|date('D, d M Y \\a\\t H:i') }}</td>
                                        </tr>
                                        {% if not booking.event.isOnline %}
                                        <tr>
                                            <td style="padding:4px 0; font-size:14px; color:#6b7280;">Venue</td>
                                            <td style="padding:4px 0; font-size:14px; color:#1f2937;">{{ booking.event.venueName }}</td>
                                        </tr>
                                        {% endif %}
                                        <tr>
                                            <td style="padding:4px 0; font-size:14px; color:#6b7280;">Booking ID</td>
                                            <td style="padding:4px 0; font-size:14px; color:#1f2937;">#{{ booking.id }}</td>
                                        </tr>
                                        <tr>
                                            <td style="padding:4px 0; font-size:14px; color:#6b7280;">Total Paid</td>
                                            <td style="padding:4px 0; font-size:14px; font-weight:700; color:#2EC4A1;">{{ booking.totalCredits }} credits</td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>
                        </table>

                        <!-- Ticket items -->
                        <p style="margin:0 0 12px; font-size:13px; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; color:#6b7280;">Your Tickets</p>
                        {% for item in booking.bookingItems %}
                        <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%"
                               style="margin:0 0 10px; border:1px solid #e5e7eb; border-radius:10px; overflow:hidden;">
                            <tr>
                                <td style="padding:14px 16px;">
                                    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                                        <tr>
                                            <td>
                                                <div style="font-size:14px; font-weight:700; color:#1f2937;">{{ item.ticketTier.name }}</div>
                                                <div style="font-size:13px; color:#6b7280; margin-top:2px;">{{ item.quantity }} ticket{% if item.quantity > 1 %}s{% endif %} × {{ item.unitPrice }} credits</div>
                                            </td>
                                            <td align="right" style="font-size:14px; font-weight:700; color:#1f2937;">{{ item.subtotal }} credits</td>
                                        </tr>
                                        {% if item.eTicket and item.eTicket.qrToken %}
                                        <tr>
                                            <td colspan="2" style="padding-top:10px;">
                                                <a href="{{ absolute_url(path('api_tickets_download', { qrToken: item.eTicket.qrToken })) }}"
                                                   style="display:inline-block; padding:8px 16px; font-size:12px; font-weight:700; color:#ffffff; background:#2EC4A1; border-radius:6px; text-decoration:none;">
                                                    Download Ticket
                                                </a>
                                            </td>
                                        </tr>
                                        {% endif %}
                                    </table>
                                </td>
                            </tr>
                        </table>
                        {% endfor %}

                        <p style="margin:24px 0 0; font-size:13px; line-height:1.7; color:#9ca3af;">
                            You can also view your tickets at any time in your account's booking history.
                        </p>
                    </td>
                </tr>

                <!-- Footer -->
                <tr>
                    <td style="padding:20px 32px; background:#f9fafb; border-top:1px solid #e5e7eb; font-size:12px; color:#9ca3af; text-align:center;">
                        TicketSphere &mdash; This is an automated message, please do not reply.
                    </td>
                </tr>

            </table>
        </td>
    </tr>
</table>
</body>
</html>
